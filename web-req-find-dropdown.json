{"action":"evaluate","args":{"code":"(()=>{const selects=document.querySelectorAll('select');const btns=document.querySelectorAll('button');return {selects:[...selects].map(s=>({id:s.id,name:s.name,options:[...s.options].map(o=>o.value)})),dropdownBtns:[...btns].filter(b=>b.textContent.includes('None')||b.getAttribute('aria-haspopup')==='true').map(b=>({text:b.textContent.trim(),className:b.className}))}})()"}}